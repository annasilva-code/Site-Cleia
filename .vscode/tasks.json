{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup: Banco + Backend",
      "type": "shell",
      "command": "docker compose up -d db && ([ -f backend/.env ] || cp backend/.env.example backend/.env) && cd backend && npm install",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Start: Backend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Stop: Banco",
      "type": "shell",
      "command": "docker compose stop db",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
